/* ─────────────────────────────────────────────
   Hero Slider
───────────────────────────────────────────── */
function HeroSlider({ slides, label, subtitle }: { slides: string[]; label: string; subtitle: string }) {
  const [active, setActive] = useState(0);

  return (
    <section className="relative h-[40vh] overflow-hidden bg-onyx">
      {slides.map((src, i) => (
        <div
          key={src}
          className={`absolute inset-0 transition-opacity duration-[1200ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] ${
            i === active ? "opacity-100" : "opacity-0"
          }`}
        >
          <Image
            src={src}
            alt={`${label} hero ${i + 1}`}
            fill
            priority={i === 0}
            sizes="100vw"
            className="object-cover object-center scale-105 group-hover:scale-110"
          />
        </div>
      ))}
      {/* Overlays */}
      <div className="absolute inset-0 bg-gradient-to-t from-onyx/70 via-onyx/20 to-transparent" />
      <div className="absolute inset-0 bg-gradient-to-r from-onyx/30 to-transparent" />

      {/* Text */}
      <div className="absolute inset-0 flex flex-col justify-end px-8 pb-10 lg:px-16 lg:pb-14 max-w-2xl">
        <motion.p
          key={`sub-${active}`}
          initial={{ opacity: 0, y: 10 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.7, delay: 0.1 }}
          className="text-gold text-[10px] tracking-[0.3em] uppercase mb-3 font-sans"
        >
          {subtitle}
        </motion.p>
        <motion.h1
          key={`h-${active}`}
          initial={{ opacity: 0, y: 16 }}
          animate={{ opacity: 1, y: 0 }}
          transition={{ duration: 0.85, delay: 0.2, ease }}
          className="font-serif text-white text-4xl lg:text-5xl leading-tight"
        >
          {label}
        </motion.h1>
      </div>

      {/* Slide dots */}
      {slides.length > 1 && (
        <div className="absolute bottom-6 right-8 flex gap-2 lg:right-16">
          {slides.map((_, i) => (
            <button
              key={i}
              onClick={() => setActive(i)}
              aria-label={`Slayt ${i + 1}`}
              className={`transition-all duration-300 ${
                i === active ? "w-6 h-px bg-gold" : "w-2 h-px bg-white/40 hover:bg-white/70"
              }`}
            />
          ))}
        </div>
      )}
    </section>
  );
}

/* ─────────────────────────────────────────────
   Active Filter Chips
───────────────────────────────────────────── */
function ActiveChips({
  filters,
  onRemove,
  onClearAll,
}: {
  filters: FilterState;
  onRemove: (key: keyof FilterState, value: string) => void;
  onClearAll: () => void;
}) {
  const chips: { key: keyof FilterState; value: string; label: string }[] = [];

  filters.materials.forEach((v) => {
    const opt = FILTER_GROUPS[0].options.find((o) => o.value === v);
    if (opt) chips.push({ key: "materials", value: v, label: opt.label });
  });
  filters.stoneTypes.forEach((v) => {
    const opt = FILTER_GROUPS[1].options.find((o) => o.value === v);
    if (opt) chips.push({ key: "stoneTypes", value: v, label: opt.label });
  });
  if (filters.priceRange) {
    const opt = FILTER_GROUPS[2].options.find((o) => o.value === filters.priceRange);
    if (opt) chips.push({ key: "priceRange", value: filters.priceRange, label: opt.label });
  }

  if (chips.length === 0) return null;

  return (
    <motion.div
      initial={{ opacity: 0, y: -8 }}
      animate={{ opacity: 1, y: 0 }}
      exit={{ opacity: 0, y: -8 }}
      className="flex flex-wrap items-center gap-2 px-6 lg:px-0 py-4 border-b border-charcoal/8"
    >
      {chips.map((chip) => (
        <button
          key={`${chip.key}-${chip.value}`}
          onClick={() => onRemove(chip.key, chip.value)}
          className="inline-flex items-center gap-1.5 border border-charcoal/20 px-3 py-1.5 text-[9px] tracking-[0.18em] uppercase font-sans text-charcoal/70 hover:border-charcoal/50 hover:text-charcoal transition-colors duration-200"
        >
          {chip.label}
          <svg viewBox="0 0 16 16" fill="none" className="w-2.5 h-2.5">
            <path d="M12 4L4 12M4 4l8 8" stroke="currentColor" strokeWidth="1.4" />
          </svg>
        </button>
      ))}
      <button
        onClick={onClearAll}
        className="text-[9px] tracking-[0.18em] uppercase font-sans text-charcoal/40 hover:text-gold border-b border-charcoal/20 hover:border-gold/40 pb-px transition-all duration-200 ml-2"
      >
        Tümünü Temizle
      </button>
    </motion.div>
  );
}

/* ─────────────────────────────────────────────
   Main Component
───────────────────────────────────────────── */
export default function CategoryPageClient({ slug }: { slug: string }) {
  const meta = CATEGORY_META[slug] ?? CATEGORY_META["halkalar"];

  const [filters, setFilters] = useState<FilterState>({
    materials: [],
    stoneTypes: [],
    priceRange: null,
    sort: "featured",
  });
  const [openAccordion, setOpenAccordion] = useState<string | null>("Materyal");
  const [sidebarOpen, setSidebarOpen] = useState(false);

  const toggleFilter = (key: keyof FilterState, value: string) => {
    if (key === "sort") {
      setFilters((prev) => ({ ...prev, sort: value }));
    } else if (key === "priceRange") {
      setFilters((prev) => ({
        ...prev,
        priceRange: prev.priceRange === value ? null : value,
      }));
    } else {
      setFilters((prev) => {
        const arr = prev[key] as string[];
        return {
          ...prev,
          [key]: arr.includes(value) ? arr.filter((v) => v !== value) : [...arr, value],
        };
      });
    }
  };

  const removeFilter = (key: keyof FilterState, value: string) => {
    if (key === "sort") return;
    if (key === "priceRange") {
      setFilters((prev) => ({ ...prev, priceRange: null }));
    } else {
      setFilters((prev) => ({
        ...prev,
        [key]: (prev[key] as string[]).filter((v) => v !== value),
      }));
    }
  };

  const clearAll = () =>
    setFilters({ materials: [], stoneTypes: [], priceRange: null, sort: "featured" });

  const categoryProducts = useMemo(
    () => products.filter((p) => p.categorySlug === slug && !p.isExclusive),
    [slug]
  );

  const displayProducts = useMemo(() => {
    const filtered = categoryProducts.filter((p) => matchesFilters(p, filters));
    return applySorting(filtered, filters.sort);
  }, [categoryProducts, filters]);

  const gridItems = useMemo(
    () => buildGridItems(displayProducts, meta.editorialCards),
    [displayProducts, meta.editorialCards]
  );

  const totalActiveFilters =
    filters.materials.length + filters.stoneTypes.length + (filters.priceRange ? 1 : 0);

  const SidebarContent = (
    <div className="space-y-0">
      {/* Category header */}
      <div className="pb-6 mb-2 border-b border-charcoal/10">
        <p className="text-[9px] tracking-[0.3em] uppercase text-gold font-sans mb-1">Filtrele</p>
        <p className="font-serif text-charcoal text-lg">{meta.label}</p>
        <p className="text-[11px] font-sans text-charcoal/40 mt-0.5">
          {displayProducts.length} ürün
        </p>
      </div>

      {FILTER_GROUPS.map((group) => (
        <FilterAccordion
          key={group.key}
          group={group}
          filters={filters}
          onToggle={toggleFilter}
          open={openAccordion === group.label}
          onOpen={() => setOpenAccordion(openAccordion === group.label ? null : group.label)}
        />
      ))}

      {totalActiveFilters > 0 && (
        <div className="pt-5">
          <button
            onClick={clearAll}
            className="w-full border border-charcoal/20 py-2.5 text-[9px] tracking-[0.22em] uppercase font-sans text-charcoal/50 hover:border-charcoal/50 hover:text-charcoal transition-all duration-200"
          >
            Filtreleri Temizle ({totalActiveFilters})
          </button>
        </div>
      )}
    </div>
  );

  return (
    <PageWrapper>
      <Navbar />
      <main className="min-h-screen bg-[#FAF9F6]">

        {/* ── Hero Slider ──────────────────────────────── */}
        <HeroSlider slides={meta.heroSlides} label={meta.label} subtitle={meta.subtitle} />

        {/* ── Breadcrumb ───────────────────────────────── */}
        <div className="px-6 lg:px-8 xl:px-16 py-4 flex items-center gap-2 border-b border-charcoal/8">
          <Link href="/" className="text-[10px] tracking-widest uppercase text-charcoal/35 hover:text-charcoal font-sans transition-colors duration-200">
            Ana Sayfa
          </Link>
          <span className="text-charcoal/20 text-[10px]">/</span>
          <Link href="/koleksiyonlar" className="text-[10px] tracking-widest uppercase text-charcoal/35 hover:text-charcoal font-sans transition-colors duration-200">
            Koleksiyonlar
          </Link>
          <span className="text-charcoal/20 text-[10px]">/</span>
          <span className="text-[10px] tracking-widest uppercase text-charcoal font-sans">
            {meta.label}
          </span>
        </div>

        {/* ── Main Layout ──────────────────────────────── */}
        <div className="flex px-6 lg:px-8 xl:px-16 py-8 lg:py-12 gap-8 lg:gap-12 max-w-screen-2xl mx-auto">

          {/* Sidebar — desktop */}
          <aside className="hidden lg:block w-[220px] xl:w-[240px] flex-shrink-0">
            <div className="sticky top-[88px] max-h-[calc(100vh-120px)] overflow-y-auto pr-2 scrollbar-thin">
              {SidebarContent}
            </div>
          </aside>

          {/* Grid area */}
          <div className="flex-1 min-w-0">

            {/* Mobile filter toggle */}
            <div className="lg:hidden flex items-center justify-between mb-6">
              <p className="text-[11px] tracking-widest uppercase text-charcoal/50 font-sans">
                {displayProducts.length} ürün
              </p>
              <button
                onClick={() => setSidebarOpen(true)}
                className="flex items-center gap-2 border border-charcoal/20 px-4 py-2 text-[9px] tracking-[0.2em] uppercase font-sans text-charcoal hover:border-charcoal/50 transition-colors duration-200"
              >
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.3" className="w-3.5 h-3.5">
                  <line x1="4" y1="6" x2="20" y2="6" />
                  <line x1="8" y1="12" x2="20" y2="12" />
                  <line x1="12" y1="18" x2="20" y2="18" />
                </svg>
                Filtrele
                {totalActiveFilters > 0 && (
                  <span className="w-4 h-4 rounded-full bg-onyx text-white text-[8px] flex items-center justify-center">
                    {totalActiveFilters}
                  </span>
                )}
              </button>
            </div>

            {/* Active filter chips */}
            <AnimatePresence>
              {totalActiveFilters > 0 && (
                <ActiveChips
                  filters={filters}
                  onRemove={removeFilter}
                  onClearAll={clearAll}
                />
              )}
            </AnimatePresence>

            {/* Grid */}
            {displayProducts.length > 0 ? (
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8 mt-6">
                {gridItems.map((item, i) =>
                  item.type === "product" ? (
                    <ProductTile
                      key={item.product.id}
                      product={item.product}
                      index={i}
                    />
                  ) : (
                    <EditorialTile key={`ed-${i}`} card={item.card} index={i} />
                  )
                )}
              </div>
            ) : (
              <motion.div
                initial={{ opacity: 0, y: 20 }}
                animate={{ opacity: 1, y: 0 }}
                className="py-24 text-center"
              >
                <p className="text-gold text-[10px] tracking-[0.3em] uppercase font-sans mb-4">Sonuç Bulunamadı</p>
                <p className="font-serif text-charcoal text-xl mb-6">
                  Bu filtrelerle eşleşen ürün yok
                </p>
                <button
                  onClick={clearAll}
                  className="border border-charcoal/25 px-8 py-3 text-[9px] tracking-[0.22em] uppercase font-sans text-charcoal hover:border-charcoal transition-colors duration-200"
                >
                  Filtreleri Temizle
                </button>
              </motion.div>
            )}
          </div>
        </div>

        {/* ── Mobile Sidebar Drawer ────────────────────── */}
        <AnimatePresence>
          {sidebarOpen && (
            <>
              <motion.div
                initial={{ opacity: 0 }}
                animate={{ opacity: 1 }}
                exit={{ opacity: 0 }}
                className="fixed inset-0 z-40 bg-onyx/50 backdrop-blur-sm lg:hidden"
                onClick={() => setSidebarOpen(false)}
              />
              <motion.aside
                initial={{ x: "-100%" }}
                animate={{ x: 0 }}
                exit={{ x: "-100%" }}
                transition={{ duration: 0.4, ease }}
                className="fixed left-0 top-0 bottom-0 z-50 w-72 bg-[#FAF9F6] overflow-y-auto p-6 lg:hidden"
              >
                <div className="flex items-center justify-between mb-6">
                  <p className="text-[10px] tracking-[0.3em] uppercase text-charcoal font-sans font-medium">
                    Filtrele
                  </p>
                  <button
                    onClick={() => setSidebarOpen(false)}
                    aria-label="Kapat"
                    className="w-8 h-8 flex items-center justify-center text-charcoal/40 hover:text-charcoal"
                  >
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" strokeWidth="1.4" className="w-5 h-5">
                      <path d="M18 6L6 18M6 6l12 12" />
                    </svg>
                  </button>
                </div>
                {SidebarContent}
                {totalActiveFilters > 0 && (
                  <button
                    onClick={() => { clearAll(); setSidebarOpen(false); }}
                    className="w-full mt-4 bg-onyx text-white py-3.5 text-[9px] tracking-[0.22em] uppercase font-sans"
                  >
                    Temizle ve Kapat
                  </button>
                )}
                <button
                  onClick={() => setSidebarOpen(false)}
                  className="w-full mt-3 border border-charcoal/20 py-3 text-[9px] tracking-[0.22em] uppercase font-sans text-charcoal"
                >
                  Sonuçları Gör ({displayProducts.length})
                </button>
              </motion.aside>
            </>
          )}
        </AnimatePresence>

        {/* ── Category CTA ────────────────────────────── */}
        <section className="bg-onyx py-20 lg:py-24 px-6 lg:px-16 mt-12">
          <motion.div
            initial={{ opacity: 0, y: 24 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.9, ease }}
            className="max-w-screen-xl mx-auto flex flex-col md:flex-row items-start md:items-center justify-between gap-8"
          >
            <div>
              <p className="text-gold text-[10px] tracking-[0.3em] uppercase mb-4 font-sans">
                Özel Danışmanlık
              </p>
              <h2 className="font-serif text-white text-3xl lg:text-4xl mb-3">
                Sizin İçin Seçelim
              </h2>
              <p className="text-zinc-300 font-sans font-light text-[13px] leading-[1.85] max-w-md">
                Uzman kuyumcularımız, ihtiyacınıza en uygun parçayı birlikte bulmak için hazır.
              </p>
            </div>
            <div className="flex flex-col sm:flex-row items-start sm:items-center gap-4">
              <Link
                href="/iletisim"
                className="border border-ivory/30 px-10 py-3.5 text-[10px] tracking-[0.2em] uppercase text-white hover:bg-white hover:text-onyx transition-all duration-300 font-sans whitespace-nowrap"
              >
                Randevu Alın
              </Link>
              <Link
                href="/koleksiyonlar"
                className="text-[10px] text-zinc-400 hover:text-gold tracking-[0.2em] uppercase border-b border-zinc-500/40 hover:border-gold/40 pb-0.5 transition-all duration-300 font-sans whitespace-nowrap"
              >
                Tüm Koleksiyonlar
              </Link>
            </div>
          </motion.div>
        </section>

      </main>
      <Footer />
    </PageWrapper>
  );
}
