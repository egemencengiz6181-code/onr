/* ─────────────────────────────────────────────
   Filter definitions
───────────────────────────────────────────── */
const FILTER_GROUPS = [
  {
    key: "materials" as const,
    label: "Materyal",
    options: [
      { label: "14K Altın", value: "14K" },
      { label: "18K Altın", value: "18K" },
      { label: "Platin", value: "Platin" },
      { label: "Rose Gold", value: "Rose Gold" },
    ],
  },
  {
    key: "stoneTypes" as const,
    label: "Taş Türü",
    options: [
      { label: "Pırlanta", value: "Pırlanta" },
      { label: "Safir", value: "Safir" },
      { label: "Zümrüt", value: "Zümrüt" },
      { label: "Turmalin", value: "Turmalin" },
    ],
  },
  {
    key: "priceRange" as const,
    label: "Fiyat Aralığı",
    options: [
      { label: "₺0 — ₺75.000", value: "0-75000" },
      { label: "₺75.000 — ₺150.000", value: "75000-150000" },
      { label: "₺150.000 — ₺300.000", value: "150000-300000" },
      { label: "₺300.000+", value: "300000-9999999" },
    ],
  },
  {
    key: "sort" as const,
    label: "Sıralama",
    options: [
      { label: "Öne Çıkanlar", value: "featured" },
      { label: "Fiyat: Düşükten Yükseğe", value: "price-asc" },
      { label: "Fiyat: Yüksekten Düşüğe", value: "price-desc" },
      { label: "Yeni Gelenler", value: "new" },
    ],
  },
];

interface FilterState {
  materials: string[];
  stoneTypes: string[];
  priceRange: string | null;
  sort: string;
}

function matchesFilters(product: Product, filters: FilterState): boolean {
  // Material filter
  if (filters.materials.length > 0) {
    const matStr = product.materials.join(" ").toLowerCase();
    const match = filters.materials.some((f) => matStr.includes(f.toLowerCase()));
    if (!match) return false;
  }
  // Stone type filter
  if (filters.stoneTypes.length > 0) {
    const matStr = product.materials.join(" ").toLowerCase();
    const match = filters.stoneTypes.some((f) => matStr.includes(f.toLowerCase()));
    if (!match) return false;
  }
  // Price range
  if (filters.priceRange) {
    const [min, max] = filters.priceRange.split("-").map(Number);
    if (product.price < min || product.price > max) return false;
  }
  return true;
}

function applySorting(prods: Product[], sort: string): Product[] {
  const arr = [...prods];
  if (sort === "price-asc") return arr.sort((a, b) => a.price - b.price);
  if (sort === "price-desc") return arr.sort((a, b) => b.price - a.price);
  if (sort === "new") return arr.sort((a, b) => (b.isNew ? 1 : 0) - (a.isNew ? 1 : 0));
  return arr;
}

/* ─────────────────────────────────────────────
   Grid item types
───────────────────────────────────────────── */
type GridItem =
  | { type: "product"; product: Product }
  | { type: "editorial"; card: EditorialCard };

function buildGridItems(filteredProducts: Product[], editorialCards: EditorialCard[]): GridItem[] {
  const items: GridItem[] = [];
  let eidx = 0;
  filteredProducts.forEach((product, i) => {
    items.push({ type: "product", product });
    // Insert editorial after every 3rd product
    if ((i + 1) % 3 === 0 && eidx < editorialCards.length) {
      items.push({ type: "editorial", card: editorialCards[eidx++] });
    }
  });
  return items;
}

/* ─────────────────────────────────────────────
   Accordion Filter Group
───────────────────────────────────────────── */
function FilterAccordion({
  group,
  filters,
  onToggle,
  open,
  onOpen,
}: {
  group: (typeof FILTER_GROUPS)[number];
  filters: FilterState;
  onToggle: (key: keyof FilterState, value: string) => void;
  open: boolean;
  onOpen: () => void;
}) {
  const key = group.key;

  const isSelected = (val: string) => {
    const v = filters[key];
    if (key === "sort") return v === val;
    if (Array.isArray(v)) return v.includes(val);
    return v === val;
  };

  const count =
    key === "sort"
      ? 0
      : Array.isArray(filters[key])
      ? (filters[key] as string[]).length
      : filters[key]
      ? 1
      : 0;

  return (
    <div className="border-b border-charcoal/10">
      <button
        onClick={onOpen}
        className="w-full flex items-center justify-between py-4 text-left group"
        aria-expanded={open}
      >
        <span className="flex items-center gap-2">
          <span className="text-[10px] tracking-[0.22em] uppercase text-charcoal font-sans font-medium">
            {group.label}
          </span>
          {count > 0 && (
            <span className="w-4 h-4 rounded-full bg-onyx text-white text-[8px] flex items-center justify-center font-sans">
              {count}
            </span>
          )}
        </span>
        <motion.svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          strokeWidth="1.3"
          className="w-3.5 h-3.5 text-charcoal/40"
          animate={{ rotate: open ? 180 : 0 }}
          transition={{ duration: 0.3 }}
        >
          <path d="M6 9l6 6 6-6" />
        </motion.svg>
      </button>

      <AnimatePresence initial={false}>
        {open && (
          <motion.div
            key="content"
            initial={{ height: 0, opacity: 0 }}
            animate={{ height: "auto", opacity: 1 }}
            exit={{ height: 0, opacity: 0 }}
            transition={{ duration: 0.35, ease }}
            className="overflow-hidden"
          >
            <div className="pb-4 space-y-2.5">
              {group.options.map((opt) => (
                <label
                  key={opt.value}
                  className="flex items-center gap-3 cursor-pointer group/opt"
                >
                  <div
                    className={`w-3.5 h-3.5 border flex-shrink-0 flex items-center justify-center transition-all duration-200 ${
                      isSelected(opt.value)
                        ? "border-onyx bg-onyx"
                        : "border-charcoal/25 group-hover/opt:border-charcoal/60"
                    }`}
                    onClick={() => onToggle(key, opt.value)}
                  >
                    {isSelected(opt.value) && (
                      <svg viewBox="0 0 10 10" className="w-2 h-2" fill="none">
                        <path d="M1.5 5l2.5 2.5 4.5-4.5" stroke="#FAF9F6" strokeWidth="1.5" strokeLinecap="round" />
                      </svg>
                    )}
                  </div>
                  <span
                    className={`text-[11px] tracking-widest uppercase font-sans transition-colors duration-200 ${
                      isSelected(opt.value) ? "text-charcoal" : "text-charcoal/50 group-hover/opt:text-charcoal/80"
                    }`}
                    onClick={() => onToggle(key, opt.value)}
                  >
                    {opt.label}
                  </span>
                </label>
              ))}
            </div>
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
}

/* ─────────────────────────────────────────────
   Product Tile
───────────────────────────────────────────── */
